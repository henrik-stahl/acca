# ─────────────────────────────────────────────
# Database (Turso / libSQL)
# ─────────────────────────────────────────────
# Local development: use a file-based SQLite database (no auth token needed)
DATABASE_URL="file:./prisma/dev.db"

# Production / staging: use your Turso database URL and auth token
# DATABASE_URL="libsql://your-database-name.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# ─────────────────────────────────────────────
# NextAuth
# ─────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-random-secret"

# The public URL of this deployment (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-app.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────
# Production: use Gmail or another SMTP provider
# EMAIL_HOST="smtp.gmail.com"
# EMAIL_PORT="587"

# Staging: use Mailtrap to capture emails without delivering them
# EMAIL_HOST="sandbox.smtp.mailtrap.io"
# EMAIL_PORT="2525"

EMAIL_HOST="smtp.gmail.com"
EMAIL_PORT="587"
EMAIL_SERVER_USER="your-email@gmail.com"
EMAIL_SERVER_PASSWORD="your-app-password"
EMAIL_FROM="your-email@gmail.com"

# ─────────────────────────────────────────────
# Vercel Blob (profile image storage)
# ─────────────────────────────────────────────
# Obtain from: Vercel dashboard → Storage → Blob → your store → .env.local
# If not set, avatar uploads return 501 (safe to omit for local development)
BLOB_READ_WRITE_TOKEN=""

# ─────────────────────────────────────────────
# Staging environment
# ─────────────────────────────────────────────
# Set on the staging Vercel project only.
# When set, all app routes require HTTP Basic Auth with this password.
# STAGING_PASSWORD="a-strong-password"

# Set to "staging" on the staging Vercel project to show the STAGING banner.
# NEXT_PUBLIC_ENVIRONMENT="staging"

# ─────────────────────────────────────────────
# Database seed (first admin user)
# ─────────────────────────────────────────────
# Used by: npm run db:seed
# Set these before running the seed script on a fresh database.
SEED_ADMIN_EMAIL="your-email@example.com"
SEED_ADMIN_NAME="Your Name"
